# Copy to .env and fill in. .env is gitignored.

# Required — Claude, used for report generation and the citation/gold-set evals
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required only for the Ragas + safety evals (used as the LLM judge)
OPENAI_API_KEY=sk-your-key-here

# Optional — backend URL the Streamlit frontend calls (default shown)
# BACKEND_URL=http://localhost:8000

# Optional — override the MedCPT data dir containing embeds/ pmids/ pubmed/
# MEDCPT_DIR=/absolute/path/to/data/MedCPT
